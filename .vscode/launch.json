{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Lancer mon a.out",
			"type": "cppdbg",
			"request": "launch",
			"program": "${workspaceFolder}/srcs/buildin/a.out",
			"args": ["env"],
			"stopAtEntry": false,
			"cwd": "${workspaceFolder}",
			"MIMode": "gdb",
			"setupCommands": [
				{
					"text": "-enable-pretty-printing",
					"ignoreFailures": true
				}
			]
		}
	]
}